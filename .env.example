# PostgreSQL local development
POSTGRES_DB=proofchain
POSTGRES_USER=proofchain
POSTGRES_PASSWORD=change_me_postgres_password
POSTGRES_PORT=5432

# Use this when the API runs directly on Windows
DATABASE_URL=postgresql://proofchain:change_me_postgres_password@localhost:5432/proofchain?schema=public

# Use this later when the API itself runs inside Docker
DATABASE_URL_DOCKER=postgresql://proofchain:change_me_postgres_password@postgres:5432/proofchain?schema=public

# MinIO local development
MINIO_ROOT_USER=proofchain_admin
MINIO_ROOT_PASSWORD=change_me_minio_password
MINIO_BUCKET=proofchain-evidence
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ENDPOINT=localhost
MINIO_USE_SSL=false

# Application
API_PORT=4000
WEB_PORT=3000
CORS_ORIGIN=http://localhost:3000

# Authentication - replace before implementing login
JWT_ACCESS_SECRET=change_me_to_a_long_random_access_secret
JWT_REFRESH_SECRET=change_me_to_a_different_long_random_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
